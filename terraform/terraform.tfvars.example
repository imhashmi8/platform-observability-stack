# Copy to terraform.tfvars and edit. terraform.tfvars is gitignored.

region      = "ap-south-1"
project     = "platform-obs"
environment = "dev"

# --- Networking ---
vpc_cidr           = "10.0.0.0/16"
az_count           = 3
single_nat_gateway = true # true = ~$33/mo cheaper, single point of failure (fine for dev)

# --- EKS ---
cluster_version    = "1.29"
node_instance_types = ["t3.large"]
node_capacity_type = "SPOT" # ON_DEMAND for prod
node_min_size      = 2
node_max_size      = 5
node_desired_size  = 3

# Restrict API access to your IP for anything beyond a throwaway dev cluster:
# cluster_endpoint_public_access_cidrs = ["203.0.113.10/32"]

# --- DNS (optional) ---
# Leave domain_name empty to skip Route53 + external-dns entirely.
domain_name         = ""
create_route53_zone = true
