# Per-environment remote state. Rename to backend.tf and run
# `terraform init -migrate-state`. The KEY is what isolates staging from
# production — they share the bucket + lock table but never the state file.
#
# One-time bootstrap of the bucket + lock table (shared across envs):
#   aws s3api create-bucket --bucket my-platform-obs-tfstate \
#     --region ap-south-1 --create-bucket-configuration LocationConstraint=ap-south-1
#   aws s3api put-bucket-versioning --bucket my-platform-obs-tfstate \
#     --versioning-configuration Status=Enabled
#   aws dynamodb create-table --table-name platform-obs-tflock \
#     --attribute-definitions AttributeName=LockID,AttributeType=S \
#     --key-schema AttributeName=LockID,KeyType=HASH \
#     --billing-mode PAY_PER_REQUEST --region ap-south-1

terraform {
  backend "s3" {
    bucket         = "my-platform-obs-tfstate"
    key            = "platform-observability-stack/staging/terraform.tfstate"
    region         = "ap-south-1"
    dynamodb_table = "platform-obs-tflock"
    encrypt        = true
  }
}
