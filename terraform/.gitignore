# Terraform working directory and provider plugins
.terraform/
.terraform.lock.hcl

# State and its locks (never commit state; it can contain secrets)
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info

# Crash logs
crash.log
crash.*.log

# Variable files with real values / secrets
terraform.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config and saved plans
.terraformrc
terraform.rc
*.tfplan
